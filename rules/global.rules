prefix_rule(pattern=["./gradlew", "test"], decision="prompt")
prefix_rule(pattern=["docker", "images"], decision="allow")
prefix_rule(pattern=["docker", "inspect"], decision="allow")
prefix_rule(pattern=["docker", "logs"], decision="allow")
prefix_rule(pattern=["docker", "ps"], decision="allow")
prefix_rule(pattern=["docker", "system", "df"], decision="allow")
prefix_rule(pattern=["docker", "volume", "ls"], decision="allow")
prefix_rule(pattern=["gh", "auth", "status"], decision="allow")
prefix_rule(pattern=["gh", "pr", "checks"], decision="allow")
prefix_rule(pattern=["gh", "pr", "create"], decision="prompt")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="prompt")
prefix_rule(pattern=["git", "rev-parse", "--short", "HEAD"], decision="allow")
prefix_rule(pattern=["kubectl", "get"], decision="allow")
prefix_rule(pattern=["kubectl", "logs"], decision="allow")
prefix_rule(pattern=["pnpm", "audit"], decision="allow")
prefix_rule(pattern=["pnpm", "install"], decision="prompt")
