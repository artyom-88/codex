# Deny by default. New top-level paths stay private until explicitly allowlisted below.
/*

# Repo policy files
!.gitignore
!README.md
!AGENTS.md
!config.example.toml
!.pylintrc

# Repo tooling
!/.githooks/
/.githooks/__pycache__/
/.githooks/**/__pycache__/
/.githooks/*.pyc
/.githooks/**/*.pyc

# GitHub automation
!/.github/

# Sharable instructions
!/instructions/

# Sharable rules
!/rules/
/rules/*
!/rules/global.rules

# Sharable skills
!/skills/
/skills/*
!/skills/memory-refiner/
