# Deny by default. New top-level paths stay private until explicitly allowlisted below.
/*

# Repo policy files
!.gitignore
!README.md
!AGENTS.md
!config.example.toml
!.pylintrc

# Repo-local Codex guidance
!/.codex/
/.codex/*
!/.codex/AGENTS.md
!/.codex/instructions/
!/.codex/instructions/**

# Generated Python files stay private everywhere
__pycache__/
*.pyc

# Repo tooling
!/.githooks/
/.githooks/__pycache__/
/.githooks/**/__pycache__/
/.githooks/*.pyc
/.githooks/**/*.pyc

# GitHub automation
!/.github/

# Sharable instructions
!/instructions/

# Sharable rules
!/rules/
/rules/*
!/rules/global.rules

# Sharable skills
!/skills/
/skills/*
!/skills/INDEX.md
# Add an explicit allowlist entry for each new local skill that is safe to share.
!/skills/code-review/
!/skills/memory-refiner/

# Shareable telemetry tools
!/tools/
/tools/*
!/tools/signoz-codex/
