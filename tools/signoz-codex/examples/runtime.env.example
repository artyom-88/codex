# Optional runtime overrides for signoz-codex.
# This file is auto-loaded when copied to ./local/runtime.env.
# Recommended usage:
#   mkdir -p ./local
#   cp ./examples/runtime.env.example ./local/runtime.env
#   edit ./local/runtime.env
# Then run ./scripts/signoz-codex ...

# Use the active Docker context by default. Override only if you want this
# project to use a different context from the rest of your Docker CLI session.
# export DOCKER_CONTEXT=remote-dev

# Runtime resolution:
# auto     -> infer local vs remote from the Docker context endpoint
# local    -> force local-engine behavior
# remote   -> force remote-engine behavior
# export SIGNOZ_CODEX_ENGINE_MODE=auto

# Optional: pin ClickHouse passwords instead of letting the helper create and
# persist local/generated/clickhouse.env on first use.
# export SIGNOZ_CODEX_CLICKHOUSE_WRITE_PASSWORD=replace-with-local-secret
# export SIGNOZ_CODEX_CLICKHOUSE_READONLY_PASSWORD=replace-with-local-secret

# For remote Docker engines, choose where project assets are copied on the
# remote host and provide a local command that performs that sync.
# export SIGNOZ_CODEX_REMOTE_ASSETS_ROOT=/srv/signoz-codex
# export SIGNOZ_CODEX_REMOTE_ASSET_SYNC_CMD='rsync -az --delete ./common ./local/generated ./otel-collector-config.yaml docker-host:/srv/signoz-codex/'

# Override the advertised UI and OTLP host if the Docker endpoint host is not
# the same address your browser or Codex should use. For remote Docker with the
# default loopback bind, leave this unset and use an SSH tunnel so the helper
# keeps advertising localhost. If you switch the bind address to 0.0.0.0 for
# direct exposure, set this to the remote host name or IP you actually want.
# export SIGNOZ_CODEX_STACK_HOST=localhost

# Bind published UI and OTLP ports to loopback by default so the local stack is
# not reachable from other hosts. Use 0.0.0.0 only when you intentionally need
# remote/shared-host access and accept exposing local telemetry endpoints.
# export SIGNOZ_CODEX_BIND_ADDR=127.0.0.1

# Override the exact Codex OTLP endpoint if you need a non-default port or URL.
# export SIGNOZ_CODEX_OTLP_ENDPOINT=http://localhost:5317
