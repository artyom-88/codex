# Optional runtime overrides for signoz-codex.
# Source this file or copy the variables you need into your shell profile.

# Use the active Docker context by default. Override only if you want this
# project to use a different context from the rest of your Docker CLI session.
# export DOCKER_CONTEXT=minikube-vfkit

# Runtime resolution:
# auto     -> infer local vs remote from the Docker context endpoint
# local    -> force local-engine behavior
# remote   -> force remote-engine behavior without assuming minikube
# minikube -> force the minikube remote adapter
# export SIGNOZ_CODEX_ENGINE_MODE=auto

# Remote asset strategy:
# auto          -> infer minikube sync for common minikube contexts, otherwise none
# none          -> disable remote asset syncing
# minikube-sync -> sync bind-mounted assets into the selected minikube guest
# export SIGNOZ_CODEX_REMOTE_ASSET_STRATEGY=auto

# Override the advertised UI and OTLP host if the Docker endpoint host is not
# the same address your browser or Codex should use.
# export SIGNOZ_CODEX_STACK_HOST=localhost

# Override the exact Codex OTLP endpoint if you need a non-default port or URL.
# export SIGNOZ_CODEX_OTLP_ENDPOINT=http://localhost:5317

# Optional when the minikube profile cannot be inferred from the Docker context
# name. Example: DOCKER_CONTEXT=minikube-vfkit -> MINIKUBE_PROFILE=vfkit
# export MINIKUBE_PROFILE=vfkit
